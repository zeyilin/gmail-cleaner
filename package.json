{
  "name": "gmail-cleaner",
  "description": "Chrome (MV3) extension to review, group, unsubscribe, and safely clean up your Gmail inbox.",
  "private": true,
  "version": "0.2.3",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "pack": "wxt build && node scripts/pack.mjs",
    "compile": "tsc --noEmit",
    "test:logic": "tsx test/logic.test.ts",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@wxt-dev/module-react": "^1.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2",
    "wxt": "^0.19.13"
  }
}
